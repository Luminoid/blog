// Hide "Keep on posting" in Archive Page
.archive .collection-title {
  display: none !important;
}

// Inline code style 
code {
  background: #eeeeee;
  color: #555555;
}

code[class*="language-"], pre[class*="language-"] {
  font-family: 'FiraCode Nerd Font', Consolas, Monaco, 'Andale Mono', 'Ubuntu Mono', monospace;
}

// Sidebar blogroll links — tighter spacing
.links-of-blogroll-list {
  gap: 0;
}
.sidebar-inner .links-of-blogroll-item a {
  line-height: 1.4;
  font-size: 1em;
  padding: 0 5px;
}
